# Optional production/deployed API endpoint (absolute URL)
VITE_API_BASE_URL=

# Optional axios timeout override in milliseconds (default: 10000)
# Useful for slow live demos or diagnostics that intentionally wait on backend failures.
VITE_API_TIMEOUT_MS=10000

# Optional override for local Vite proxy target
VITE_DEV_PROXY_TARGET=http://localhost:8080

# Optional Grafana-backed admin monitoring descriptor.
# Generate a real local value after the observability profile is up:
#   node ../scripts/observability/generate-monitoring-panels.mjs --write-env-file .env.local
VITE_ADMIN_MONITORING_PANELS_JSON=
